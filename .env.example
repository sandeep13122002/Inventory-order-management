# Root environment file used by docker-compose.
# Copy to .env and adjust values. Do NOT commit the real .env.

# --- PostgreSQL ---
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=inventory_db
POSTGRES_PORT=5432

# --- Backend ---
# DATABASE_URL is composed from the values above inside docker-compose,
# but you can override it here for non-compose runs.
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Products at or below this quantity are flagged as "low stock".
LOW_STOCK_THRESHOLD=10

# --- Frontend ---
FRONTEND_PORT=3000
# Base URL the browser uses to reach the backend API.
VITE_API_BASE_URL=http://localhost:8000
